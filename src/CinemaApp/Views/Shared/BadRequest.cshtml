@{
    Layout = "_Layout";
    ViewData["Title"] = "400 Bad Request";
}

<div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="text-center">
        <svg width="96" height="96" fill="none" xmlns="http://www.w3.org/2000/svg" class="mb-4">
            <circle cx="48" cy="48" r="46" stroke="#dc3545" stroke-width="4" fill="#fff3f3" />
            <text x="50%" y="54%" text-anchor="middle" fill="#dc3545" font-size="48" font-family="Segoe UI, Arial, sans-serif" dy=".3em">400</text>
        </svg>
        <h1 class="display-4 text-danger mb-3">Bad Request</h1>
        <p class="lead mb-4">
            Oops! The request could not be understood by the server.<br />
            Please check the URL or try again.
        </p>
        <a href="@(Url.Action("Index", "Home"))" class="btn btn-primary btn-lg">
            Go to Home
        </a>
    </div>
</div>

<style>
    .display-4 {
        font-weight: 700;
        letter-spacing: 1px;
    }

    .lead {
        color: #6c757d;
    }

    @@media (max-width: 576px) {
        .display-4 {
            font-size: 2rem;
        }

        svg {
            width: 64px;
            height: 64px;
        }
    }
</style>
